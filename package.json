{
  "name": "secure-vault-manager",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev:desktop": "pnpm --filter desktop tauri dev",
    "build:desktop": "pnpm --filter desktop tauri build",
    "tauri": "pnpm --filter desktop tauri",
    "build:proxy": "cargo build --manifest-path packages/proxy/Cargo.toml --release",
    "copy:sidecar": "node ./scripts/copy-sidecar.js",
    "register-proxy": "node ./scripts/register-proxy.js",
    "clean": "node ./scripts/clean.js",
    "build:wasm": "wasm-pack build packages/crypto-wasm --target bundler --out-dir pkg",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.0"
  }
}
